# NOVERA AI Agent - LLM Provider Configuration
# Set at least one key for full AI intelligence. The agent tries providers in order.

# Option 1: OpenRouter (access Liquid LFM2 + many other models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Option 2: Google Gemini (generous free tier: 60 req/min)
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Option 3: HuggingFace Inference API
# Get key: https://huggingface.co/settings/tokens
HF_API_KEY=

# Advanced: Custom Liquid AI endpoint
LIQUID_API_KEY=
LIQUID_API_URL=https://openrouter.ai/api/v1/chat/completions
LIQUID_MODEL=liquid/lfm2
